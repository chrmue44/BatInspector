<Window x:Class="BatInspector.Forms.FrmPosition"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BatInspector.Controls"
        xmlns:res="clr-namespace:BatInspector.Properties"
        mc:Ignorable="d"
        Title="{x:Static res:MyResources.ExpGenCalcDist}" Height="250" Width="400">
    <Grid>
        <StackPanel Margin="10,30,10,0">
            <TextBlock x:Name="_tbHint" IsEnabled="false" Text="bla, bla" TextWrapping="Wrap" FontStyle="Italic" ></TextBlock>
            <local:ctlDataItem x:Name="_ctlLat" Margin="0,15,0,0"/>
            <local:ctlDataItem x:Name="_ctlLon" Margin="0,5,0,0"/>
            <local:ctlDataItem x:Name="_ctlDist" Margin="0,5,0,0"/>
            <Button Name="_bntOk" Click="_bntOk_Click" Width="150" Height="25" Content="OK" HorizontalAlignment="Center" Margin="10,30,5,5"/>
        </StackPanel>
    </Grid>
</Window>
